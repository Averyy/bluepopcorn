# Seerr instance
SEERR_URL=http://your-seerr-host:5055
SEERR_API_KEY=your-api-key-here

# Comma-separated phone numbers allowed to message the bot (E.164 format)
ALLOWED_SENDERS=+15551234567,+15559876543

# Webhook secret for Seerr notifications (optional, but recommended)
# Set the same value in Seerr → Settings → Notifications → Webhook → Webhook Secret
WEBHOOK_SECRET=
