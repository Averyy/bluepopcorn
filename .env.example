# === MCP Server ===
SEERR_URL=http://your-seerr-host:5055
SEERR_API_KEY=your-api-key-here
MCP_API_KEY=your-mcp-auth-key
# HTTP_PORT=8080
# HTTP_HOST=127.0.0.1
# HTTP_TIMEOUT=15
# MCP_TRUST_PROXY=false    # Set true ONLY behind a trusted reverse proxy (enables X-Forwarded-For for auth rate limiting)

# === iMessage Bot (optional, macOS only) ===
# ALLOWED_SENDERS=+15551234567,+15559876543
ANTHROPIC_API_KEY=your-anthropic-key    # Required for production. Without this, falls back to Claude Code CLI (testing only, requires daily manual login)
# WEBHOOK_SECRET=          # Recommended: shared secret for Seerr webhook auth. Without it webhooks rely on IP filtering alone (rejected entirely if the Seerr host can't be resolved)
